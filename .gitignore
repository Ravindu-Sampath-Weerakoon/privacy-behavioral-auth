# ==========================================
# 1. Datasets & Raw Logs (CRITICAL FOR LICENSING)
# ==========================================
/data_raw/
/data_processed/
*.csv
*.tsv
*.json
*.log

# ==========================================
# 2. Secret Keys & Environment Variables
# ==========================================
.env
.env.*
*.key
/secrets/
# Ensure JL-projection keys are NEVER tracked
jl_secret_key.pem 
projection_matrix.npy

# ==========================================
# 3. PyTorch & Machine Learning Models
# ==========================================
# Do not track heavy model weights or checkpoints
*.pt
*.pth
*.ckpt
/models/checkpoints/
/lightning_logs/
/runs/

# ==========================================
# 4. Python Core & Virtual Environments
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
.installed.cfg
*.egg
*.egg-info/

# Virtual Environments
venv/
.venv/
env/
.env_dir/

# ==========================================
# 5. Jupyter Notebooks & IDEs
# ==========================================
.ipynb_checkpoints
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# 6. OS Generated Files
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 7. EXCEPTION RULES: Keep README files
# ==========================================
!/data_raw/*.md
!/data_processed/*.md
!/evaluation/*.md
!/models/*.md
!/notebooks/*.md
!/src/*.md